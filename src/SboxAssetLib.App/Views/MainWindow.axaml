<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SboxAssetLib.App.ViewModels"
        xmlns:prov="using:SboxAssetLib.Core.Providers"
        xmlns:conv="using:SboxAssetLib.App.Converters"
        xmlns:sys="using:System"
        x:Class="SboxAssetLib.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="s&amp;box Asset Library"
        Width="1280" Height="820" MinWidth="900" MinHeight="600">

    <Window.Resources>
        <conv:WidthToColumnsConverter x:Key="WidthToColumns" CellWidth="186" />
    </Window.Resources>

    <Window.Styles>
        <!-- PBR channel badge -->
        <Style Selector="Border.badge">
            <Setter Property="Background" Value="#33FFFFFF" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="Margin" Value="0,0,3,3" />
        </Style>
        <Style Selector="Border.badge > TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Border.pbr">
            <Setter Property="Background" Value="#2E7D32" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="5,1" />
        </Style>
        <Style Selector="Border.tag">
            <Setter Property="Background" Value="#3A3A3A" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Margin" Value="0,0,4,4" />
        </Style>
        <Style Selector="Border.tag > TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#CCC" />
        </Style>
        <!-- Cards stretch to fill their UniformGrid cell (responsive width) rather than a fixed 180. -->
        <Style Selector="Border.card">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="#1E1E1E" />
        </Style>
        <!-- Install-status border: green = in reusable library, blue = in active s&box project.
             Project is declared after library so it wins when an asset is in both. -->
        <Style Selector="Border.card.installed-library">
            <Setter Property="BorderBrush" Value="#2E7D32" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="Border.card.installed-project">
            <Setter Property="BorderBrush" Value="#007ACC" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <!-- Remove the ListBoxItem container chrome/padding and let it stretch so cards fill the cell. -->
        <Style Selector="ListBox.gallery ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ===== Toolbar ===== -->
        <Border Grid.Row="0" Background="#252526" Padding="10,8" BorderBrush="#333" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Library" VerticalAlignment="Center" Foreground="#AAA" />
                <ComboBox ItemsSource="{Binding Providers}" SelectedItem="{Binding SelectedProvider}" MinWidth="130">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="prov:IAssetProvider">
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox ItemsSource="{Binding Kinds}" SelectedItem="{Binding SelectedKind}" MinWidth="100" />
                <TextBox Text="{Binding SearchText}" PlaceholderText="Search… (e.g. wood, brick, rock)" Width="320">
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}" />
                    </TextBox.KeyBindings>
                </TextBox>
                <CheckBox Content="PBR only" IsChecked="{Binding PbrOnly}" VerticalAlignment="Center" />
                <Button Content="Search" Command="{Binding SearchCommand}" Classes="accent" />
            </StackPanel>
        </Border>

        <!-- ===== Gallery + Detail ===== -->
        <Grid Grid.Row="1" ColumnDefinitions="*,380">

            <DockPanel Grid.Column="0">
                <Button DockPanel.Dock="Bottom" Content="Load more results"
                        Command="{Binding LoadMoreCommand}" IsVisible="{Binding HasMore}"
                        HorizontalAlignment="Center" Margin="0,8" />
                <ListBox Classes="gallery" ItemsSource="{Binding Results}" SelectedItem="{Binding Selected}"
                         Background="Transparent" Padding="3"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <!-- Column count tracks the available width; cards stretch to fill the row so
                                 there's never a leftover side gap, and snap to a new column when one fits. -->
                            <UniformGrid Columns="{Binding $parent[ListBox].Bounds.Width,
                                                   Converter={StaticResource WidthToColumns}}" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:AssetCardViewModel">
                            <Border Classes="card" ClipToBounds="True"
                                    Classes.installed-library="{Binding InstalledInLibrary}"
                                    Classes.installed-project="{Binding InstalledInProject}">
                                <StackPanel>
                                    <Border CornerRadius="6,6,0,0" ClipToBounds="True" Height="160" Background="#111">
                                        <Image Source="{Binding Thumbnail}" Stretch="Uniform"
                                               HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                    </Border>
                                    <StackPanel Margin="6,5" Spacing="3">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding ProviderName}" Foreground="#888"
                                                   FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,-2,0,0" />
                                        <ItemsControl ItemsSource="{Binding Badges}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="sys:String">
                                                    <Border Classes="badge"><TextBlock Text="{Binding}" /></Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <DockPanel>
                                            <Border Classes="pbr" IsVisible="{Binding IsPbr}" DockPanel.Dock="Left">
                                                <TextBlock Text="PBR" FontSize="10" FontWeight="Bold" />
                                            </Border>
                                            <TextBlock Text="{Binding MaxResolution}" Foreground="#888"
                                                       FontSize="11" HorizontalAlignment="Right" />
                                        </DockPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Detail panel -->
            <Border Grid.Column="1" Background="#252526" BorderBrush="#333" BorderThickness="1,0,0,0" Padding="14">
                <Panel>
                    <TextBlock Text="Select an asset to see details and import options."
                               Foreground="#888" TextWrapping="Wrap" VerticalAlignment="Center"
                               HorizontalAlignment="Center" IsVisible="{Binding !HasSelection}" />

                    <ScrollViewer IsVisible="{Binding HasSelection}">
                        <!-- Right margin keeps content clear of the overlay scrollbar so it never
                             sits on top of the text/tags, collapsed or expanded (hover) state. -->
                        <StackPanel Spacing="10" Margin="0,0,16,0">
                            <Border x:Name="PreviewImage" CornerRadius="6" ClipToBounds="True" Background="#111"
                                    HorizontalAlignment="Stretch" Height="{Binding #PreviewImage.Bounds.Width}">
                                <Image Source="{Binding Selected.Thumbnail}" Stretch="Uniform" />
                            </Border>
                            <TextBlock Text="{Binding Selected.Name}" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding Selected.ProviderName}" Foreground="#AAA" FontSize="12" />
                                <TextBlock Text="{Binding Selected.AuthorsText}" Foreground="#888" FontSize="12" />
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding Selected.Badges}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="sys:String">
                                        <Border Classes="badge"><TextBlock Text="{Binding}" /></Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="{Binding Selected.Detail.Description}" Foreground="#CCC"
                                       FontSize="12" TextWrapping="Wrap" />

                            <ItemsControl ItemsSource="{Binding Selected.Tags}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="sys:String">
                                        <Border Classes="tag"><TextBlock Text="{Binding}" /></Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Margin="0,4">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Resolution" VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Resolutions}"
                                          SelectedItem="{Binding SelectedResolution}" HorizontalAlignment="Stretch" />
                            </Grid>

                            <CheckBox Content="Generate separate kit models"
                                      IsChecked="{Binding ImportAsKit}"
                                      IsVisible="{Binding CanImportAsKit}"
                                      ToolTip.Tip="Creates one filtered VMDL for each named mesh component, plus the full model." />

                            <TextBlock Text="Library folder" Foreground="#AAA" FontSize="12" />
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="…" Command="{Binding BrowseLibraryCommand}"
                                        Margin="6,0,0,0" />
                                <TextBox Text="{Binding LibraryPath}" />
                            </DockPanel>

                            <Button Content="Add to Library" Command="{Binding AddToLibraryCommand}"
                                    IsEnabled="{Binding HasSelection}" HorizontalAlignment="Stretch" />
                            <Button Content="Import to s&amp;box" Command="{Binding ImportToSboxCommand}"
                                    IsEnabled="{Binding HasSelection}" HorizontalAlignment="Stretch" Classes="accent" />

                            <DockPanel Margin="0,2,0,0">
                                <Button DockPanel.Dock="Right" Content="Open page ↗" Command="{Binding OpenSourceCommand}"
                                        Padding="8,2" FontSize="11" />
                                <TextBlock Text="{Binding Selected.LicenseText}" Foreground="#888" FontSize="11"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Panel>
            </Border>
        </Grid>

        <!-- ===== Status bar ===== -->
        <Border Grid.Row="2" Background="#007ACC" Padding="10,4">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Content="↻" Command="{Binding CheckBridgeCommand}"
                        Padding="6,0" Background="Transparent" BorderThickness="0" />
                <TextBlock DockPanel.Dock="Right" Text="{Binding BridgeStatus}" VerticalAlignment="Center"
                           Margin="0,0,8,0" Foreground="White" />
                <ProgressBar DockPanel.Dock="Right" Width="160" Maximum="100" Value="{Binding Progress}"
                             IsVisible="{Binding IsBusy}" Margin="0,0,12,0" />
                <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Foreground="White"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
